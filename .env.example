# Copy to `.env` and fill in. Do not commit `.env` (see `.gitignore`).

# Server-only: Google Cloud key with Places API (Place Details) enabled.
# Used by `src/lib/googlePlace.ts` for live rating fetch.
GOOGLE_MAPS_API_KEY=

# Public: your Google Maps Place ID (safe to expose; used for Maps links / ratings).
NEXT_PUBLIC_GOOGLE_PLACE_ID=
